<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/detailPage.css">
    <title><%= pokemon.name %> • Pokémon detail</title>
</head>
<body>
    <%- include('partials/navBar') %>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="/trainers/edit/<%= trainer.id %>" class="btn btn-outline-secondary btn-back"> Edit</a>
            <span class="text-muted">Trainer detail</span>
        </div>

        <div class="row g-4 trainers-detail-card p-0">
            <div class="col-12 col-lg-5 trainers-image-card">
                <div class="trainers-name-badge">#<%= trainer.id %> <%= trainer.name %></div>
                <img src="<%= trainer.image_path %>" alt="<%= trainer.name %>">
            </div>

            <div class="col-12 col-lg-7 p-4">
                <div class="detail-box">
                    <h5>Description</h5>
                    <p class="mb-0 text-muted"><%= trainer.description || 'No description available for this trainer.' %></p>
                </div>

                <div class="detail-box" >
                    <h5>Pokemon</h5>
                    <div class="pokemon-list">
                        <% if (pokemon && pokemon.length > 0) { %>
                        <% pokemon.forEach(poke => { %>
                            <a href="/pokemon/<%= poke.id %>" class="text-decoration-none">
                            <div class="pokemon-card">
                                <img src="<%= poke.image_path %>" alt="<%= poke.name %>">
                            </div>
                            </a>
                        <% }) %>
                    <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
