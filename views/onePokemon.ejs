<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/detailPage.css">
    <title><%= pokemon.name %> • Pokémon detail</title>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelector(".delete-btn").addEventListener("click", async (e) => {
                const id = e.target.dataset.id;

                await fetch(`/pokemon/delete/${id}`, {
                    method: "POST"
                });

                window.location.href = "/pokemon";
            });
        });
    </script>
</head>
<body>
    <%- include('partials/navBar') %>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="/pokemon/edit/<%= pokemon.id %>" class="btn btn-outline-secondary btn-back"> Edit</a>
                <button class="btn btn-outline-secondary btn-back delete-btn" data-id="<%= pokemon.id%>"> Delete </button>
            </div>
            <span class="text-muted">Pokémon detail</span>
        </div>

        <div class="row g-4 pokemon-detail-card p-0">
            <div class="col-12 col-lg-5 pokemon-image-card">
                <div class="pokemon-name-badge">#<%= pokemon.id %> <%= pokemon.name %></div>
                <img src="<%= pokemon.pokemon_image %>" alt="<%= pokemon.name %>">
            </div>

            <div class="col-12 col-lg-7 p-4">
                <div class="detail-box">
                    <h5>Description</h5>
                    <p class="mb-0 text-muted"><%= pokemon.description || 'No description available for this Pokémon.' %></p>
                </div>

                <div class="detail-box">
                    <h5>Types</h5>
                    <div class="d-flex flex-wrap align-items-center">
                        <% pokemon.type_images.forEach(type => { %>
                            <span class="type-badge">
                                <img src="/images/types/<%= type %>" alt="<%= type %>">
                                <%= type.slice(0, -4) %>
                            </span>
                        <% }) %>
                    </div>
                </div>

                <div class="detail-box" >
                    <h5>Trainers</h5>
                    <div class="trainers-list">
                        <% if (trainers && trainers.length > 0) { %>
                        <% trainers.forEach(trainer => { %>
                            <a href="/trainers/<%= trainer.id %>" class="text-decoration-none">
                            <div class="trainer-card">
                                <img src="<%= trainer.image_path %>" alt="<%= trainer.name %>">
                                <div>
                                    <h6 class="mb-1"><%= trainer.name %></h6>
                                    <p class="mb-0 text-muted">Trainer for <%= pokemon.name %></p>
                                </div>
                            </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p class="mb-0 text-muted">No associated trainers found for this Pokémon.</p>
                    <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
