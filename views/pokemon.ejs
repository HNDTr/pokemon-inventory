<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% pokemons.forEach(pokemon => { %>
        <div>
           <img src="images/pokemon/<%= pokemon.image_path %>" alt="">
           <h2><%= pokemon.name %></h2>
        </div>
    <% }) %>
</body>
</html>